{
  "name": "daily-stock-analysis-desktop",
  "version": "3.21.0",
  "private": true,
  "main": "secureMain.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "test": "node --test tests/*.test.js",
    "smoke:credential-store:windows": "node scripts/windowsCredentialSmokePreflight.js",
    "smoke:settings-credential:windows": "node scripts/windowsSettingsCredentialSmokeController.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.daily-stock-analysis.desktop",
    "productName": "Daily Stock Analysis",
    "directories": {
      "output": "dist"
    },
    "files": [
      "secureMain.js",
      "credentialIpc.js",
      "main.js",
      "preload.js",
      "renderer/**/*",
      "secureCredentialStore.js"
    ],
    "extraResources": [
      {
        "from": "../../.env.example",
        "to": ".env.example"
      },
      {
        "from": "../../dist/backend/stock_analysis",
        "to": "backend/stock_analysis"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "daily-stock-analysis-windows-installer-v${version}.${ext}",
      "publish": [
        {
          "provider": "github",
          "owner": "ZhuLinsen",
          "repo": "daily_stock_analysis"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "include": "installer.nsh"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
